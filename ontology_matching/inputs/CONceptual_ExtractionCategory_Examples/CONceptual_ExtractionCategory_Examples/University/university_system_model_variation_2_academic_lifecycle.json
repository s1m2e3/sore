          "name": "applicantID",
          "type": "Identifier"
        },
        {
          "name": "applicantName",
          "type": "Name"
        },
        {
          "name": "applicationState",
          "type": "OperationalState"
        },
        {
          "name": "applicationTime",
          "type": "Time"
        }
      ]
    },
    {
      "name": "AdmissionDecision",
      "attributes": [
