{
  "modelName": "Hospital_Model_V3_FunctionalLayer",
  "modelDescription": "Functional-layer decomposition of a hospital system. Entities are organized into eight functional layers: PatientCareLayer (nursing units, rooms, beds, bedside equipment), DiagnosticsLayer (labs, imaging, cardiology, pulmonary equipment), SurgicalServicesLayer (ORs, sterile processing, pre/post-op), EmergencyServicesLayer (triage, trauma, ambulance), PharmacyLayer (central/satellite pharmacy, dispensing, compounding), BuildingInfrastructureLayer (structure, HVAC, medical gas, power, water, waste, elevators), ClinicalTechnologyLayer (network, servers, EHR, PACS, nurse call), and SupportServicesLayer (transport, dietary, housekeeping, administration). Cross-layer Associations connect equipment to spaces, staff to areas, and infrastructure to clinical zones.",
  "observables": [
    "Identifier", "Temperature", "Pressure", "Power", "Energy",
    "ElectricPotential", "ElectricCurrent", "Mass",
    "Position", "Distance", "Duration",
    "TemporalFrequency", "ScalarVolume", "ScalarArea",
    "MassFlowRate", "Ratio", "Count", "HealthState",
    "OperationalState", "Kind", "Description", "Extent",
    "Humidity", "Illuminance", "ConfigurationState", "Size",
    "DataRate", "CalendarTime", "NonPhysicalAddress",
    "Audio", "Video", "Speed", "Mode",
